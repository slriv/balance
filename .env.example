# NAS orchestration defaults
NAS_HOST=samr@nas.home
REMOTE_DIR=/volume1/docker/balance
ARTIFACTS_HOST_DIR=/volume1/docker/balance/artifacts
DOCKER_BIN=/usr/local/bin/docker
SERVICE=balance
BALANCE_MANIFEST_FILE=artifacts/balance-apply-manifest.jsonl

# Future Plex API integration (API-only path)
PLEX_BASE_URL=http://plex-host:32400
PLEX_TOKEN=replace-me
PLEX_LIBRARY_IDS=1
PLEX_PATH_MAP_FILE=config/plex-path-map.example
PLEX_REPORT_FILE=artifacts/plex-reconcile-plan.json
PLEX_RETRY_QUEUE_FILE=artifacts/plex-retry-queue.jsonl

# Sonarr reconciliation (manual remote API path)
SONARR_BASE_URL=http://sonarr-host:8989
SONARR_API_KEY=replace-me
SONARR_PATH_MAP_FILE=config/sonarr-path-map.example
SONARR_REPORT_FILE=artifacts/sonarr-reconcile-plan.json
SONARR_RETRY_QUEUE_FILE=artifacts/sonarr-retry-queue.jsonl
