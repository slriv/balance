# NAS orchestration defaults
NAS_HOST=samr@nas.home
REMOTE_DIR=/volume1/docker
DOCKER_BIN=/usr/local/bin/docker
SERVICE=balance

# Future Plex API integration (API-only path)
# PLEX_BASE_URL=http://plex-host:32400
# PLEX_TOKEN=replace-me
# PLEX_LIBRARY_IDS=1

# Sonarr reconciliation (manual remote API path)
# SONARR_BASE_URL=http://sonarr-host:8989
# SONARR_API_KEY=replace-me
# SONARR_PATH_MAP_FILE=config/sonarr-path-map.example
# SONARR_REPORT_FILE=/volume1/docker/logs/sonarr-report.json
# SONARR_RETRY_QUEUE_FILE=/volume1/docker/logs/sonarr-retry.jsonl
