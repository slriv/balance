<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title() // 'balance' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/htmx.min.js"></script>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen">
  <nav class="bg-gray-800 border-b border-gray-700 px-6 py-3 flex gap-6 text-sm font-medium">
    <a href="/"       class="hover:text-white text-gray-300">Dashboard</a>
    <a href="/sonarr" class="hover:text-white text-gray-300">Sonarr</a>
    <a href="/plex"   class="hover:text-white text-gray-300">Plex</a>
    <a href="/config" class="hover:text-white text-gray-300 ml-auto">⚙️ Config</a>
  </nav>
  <main class="p-6">
    <%= content %>
  </main>
</body>
</html>
